{
  "name": "arbitrary-numbers",
  "version": "1.1.0",
  "description": "Arbitrary-magnitude arithmetic for idle games and simulations, with fused operations, formula pipelines, and pluggable number formatting.",
  "author": "Chris",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrisitopherus/arbitrary-numbers.git"
  },
  "bugs": {
    "url": "https://github.com/chrisitopherus/arbitrary-numbers/issues"
  },
  "homepage": "https://github.com/chrisitopherus/arbitrary-numbers#readme",
  "keywords": [
    "arbitrary-numbers",
    "big-number",
    "bignumber",
    "large-number",
    "scientific-notation",
    "idle-game",
    "idle-games",
    "incremental-game",
    "incremental",
    "clicker",
    "prestige",
    "game-math",
    "notation",
    "decimal",
    "typescript"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc --noEmit && vitest run && npm run lint && tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "tsc --noEmit",
    "run:dev": "tsx src/dev.ts",
    "bench": "tsx benchmarks/arithmetic.bench.ts && tsx benchmarks/format.bench.ts && tsx benchmarks/gamePattern.bench.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^4.1.1",
    "eslint": "^10.1.0",
    "fast-check": "^4.7.0",
    "jiti": "^2.6.1",
    "mitata": "^1.0.34",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  }
}
