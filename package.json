{
  "name": "arbitrary-numbers",
  "version": "0.1.0",
  "description": "Represent, manipulate, and display numbers of any magnitude — built for idle games, simulations, and scientific computing.",
  "author": "Chris",
  "license": "MIT",
  "keywords": [
    "arbitrary-numbers",
    "big-number",
    "large-number",
    "scientific-notation",
    "idle-game",
    "incremental-game",
    "game-math",
    "typescript"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "media",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
